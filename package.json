{
  "name": "personal-site",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "dev": "node scripts/dev.mjs",
    "lint:repo": "node scripts/lint-repo.mjs",
    "migrate:photography:webp": "node scripts/migrate-photography-webp.mjs",
    "preview": "node scripts/preview.mjs",
    "test": "pnpm lint:repo && pnpm test:smoke",
    "test:smoke": "node --test tests/*.test.mjs",
    "format": "prettier -w .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "prettier": "^3.3.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^6.2.0"
  }
}
